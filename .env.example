DATABASE_URL=postgres://eunha:eunha@localhost/eunha
BIND_ADDRESS=0.0.0.0:3000
CONSOLE_DOMAIN=eunha.social

# Build without a live database (uses .sqlx offline cache):
#   SQLX_OFFLINE=true cargo build
# Regenerate the cache after changing queries:
#   DATABASE_URL=... cargo sqlx prepare

# Media storage: local or s3
MEDIA_STORAGE__TYPE=local
MEDIA_STORAGE__BASE_PATH=./media
MEDIA_STORAGE__BASE_URL=https://your-domain.example/media

# S3 example:
# MEDIA_STORAGE__TYPE=s3
# MEDIA_STORAGE__BUCKET=my-bucket
# MEDIA_STORAGE__REGION=us-east-1
# MEDIA_STORAGE__ACCESS_KEY_ID=...
# MEDIA_STORAGE__SECRET_ACCESS_KEY=...
# MEDIA_STORAGE__BASE_URL=https://cdn.example.com

# Optional SMTP
# SMTP__HOST=smtp.example.com
# SMTP__PORT=587
# SMTP__USERNAME=user
# SMTP__PASSWORD=pass
# SMTP__FROM=notifications@example.com
