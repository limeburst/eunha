  "query": "SELECT u.id, u.password_hash, a.id as account_id, a.username\n           FROM users u\n           JOIN accounts a ON a.id = u.account_id\n           WHERE u.email_normalized = $1\n             AND u.instance_id = $2\n             AND u.confirmed_at IS NOT NULL\n             AND a.domain IS NULL",
