  "query": "SELECT u.email, a.username, a.display_name, i.domain, i.custom_domain\n                   FROM users u\n                   JOIN accounts a ON a.id = u.account_id\n                   JOIN instances i ON i.id = u.instance_id\n                   WHERE u.account_id = $1 AND u.confirmed_at IS NOT NULL",
