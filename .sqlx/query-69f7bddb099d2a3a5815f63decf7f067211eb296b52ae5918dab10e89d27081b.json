  "query": "SELECT * FROM statuses\n           WHERE instance_id = $1\n             AND deleted_at IS NULL\n             AND visibility = 'public'\n             AND reblog_of_id IS NULL\n             AND created_at > now() - interval '2 days'\n           ORDER BY (favourites_count + reblogs_count * 2) DESC, created_at DESC\n           LIMIT $2",
