  "query": "SELECT id, text, published, all_day, starts_at, ends_at,\n                  published_at, created_at, updated_at\n           FROM announcements\n           WHERE instance_id = $1\n             AND published = true\n             AND (ends_at IS NULL OR ends_at > now())\n           ORDER BY published_at DESC",
