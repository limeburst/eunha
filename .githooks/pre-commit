#!/bin/bash
set -e

# Only run when console source files are staged.
if ! git diff --cached --name-only | grep -q '^console/src/'; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)/console"

echo "→ Extracting Lingui messages..."
pnpm lingui extract 2>/dev/null

# Stage updated PO files so the commit captures any newly extracted strings.
git add src/locales/*/messages.po

# Check for untranslated strings in every non-source locale.
missing_found=0
for po_file in src/locales/*/messages.po; do
  locale=$(basename "$(dirname "$po_file")")
  [ "$locale" = "en" ] && continue

  # PO files always have exactly one header entry with msgstr "".
  # Subtract that one to get the count of untranslated strings.
  total=$(grep -c '^msgstr ""$' "$po_file" 2>/dev/null || true)
  missing=$(( total - 1 ))

  if [ "$missing" -gt 0 ]; then
    echo "✗  $missing untranslated string(s) in $po_file"
    missing_found=1
  fi
done

if [ "$missing_found" -eq 1 ]; then
  echo ""
  echo "Add the missing translations, then run 'pnpm lingui compile' in console/ and re-stage."
  exit 1
fi

echo "→ Compiling Lingui catalogs..."
pnpm lingui compile 2>/dev/null
